{
  "name": "minimon.js",
  "version": "1.0.0",
  "description": "Pokemon mini emulator",
  "scripts": {
    "core": "cd core; make wasm",
    "retroarch": "cd core/libretro; make test",
    "table": "python3 ./tools/convert.py > ./src/system/table.ts",
    "check": "npm run table; tsc --noEmit",
    "start": "npm run table; vite",
    "build": "npm run table; npm run core; vite build",
    "preview": "vite preview",
    "deploy": "npm run build; scp -r dist/* node@scyl.us:~/minimon/"
  },
  "keywords": [],
  "author": "Bryon Vandiver",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asterick/minimon.js.git"
  },
  "bugs": {
    "url": "https://github.com/asterick/minimon.js/issues"
  },
  "homepage": "https://github.com/asterick/minimon.js#readme",
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "normalize.css": "^8.0.1",
    "rc-dock": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "less": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
